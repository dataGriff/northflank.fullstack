{
  "apiVersion": "v1.2",
  "arguments": {
    "GIT_REPO": "https://github.com/dataGriff/northflank.fullstack",
    "GIT_BRANCH": "main"
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "todo-fullstack",
          "spec": {
            "name": "todo-fullstack",
            "description": "Fullstack Todo application - PostgreSQL, Express API, React frontend",
            "region": "europe-west",
            "color": "#6366f1"
          }
        },
        {
          "kind": "Addon",
          "ref": "todo-db",
          "spec": {
            "projectId": "${refs.todo-fullstack.id}",
            "name": "todo-db",
            "description": "PostgreSQL database for Todo app",
            "type": "postgresql",
            "version": "16",
            "billing": {
              "deploymentPlan": "nf-compute-20",
              "storage": 4096,
              "replicas": 1
            },
            "tlsEnabled": true,
            "externalAccessEnabled": false
          }
        },
        {
          "kind": "SecretGroup",
          "ref": "api-secrets",
          "spec": {
            "projectId": "${refs.todo-fullstack.id}",
            "name": "api-secrets",
            "secretType": "environment-arguments",
            "priority": 10,
            "secrets": {
              "variables": {},
              "files": {}
            },
            "addonDependencies": [
              {
                "addonId": "${refs.todo-db.id}",
                "keys": [
                  {
                    "keyName": "CONNECTION_STRING",
                    "aliases": [
                      "DATABASE_URL"
                    ]
                  }
                ]
              }
            ],
            "restrictions": {
              "restricted": false,
              "nfObjects": [],
              "tags": []
            }
          }
        },
        {
          "kind": "CombinedService",
          "ref": "todo-api",
          "spec": {
            "projectId": "${refs.todo-fullstack.id}",
            "name": "todo-api",
            "description": "Todo REST API (Node.js / Express)",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "vcsData": {
              "projectType": "github",
              "projectUrl": "${args.GIT_REPO}",
              "projectBranch": "${args.GIT_BRANCH}"
            },
            "buildSettings": {
              "dockerfile": {
                "buildEngine": "kaniko",
                "dockerFilePath": "/api/Dockerfile",
                "dockerWorkDir": "/api"
              }
            },
            "deployment": {
              "instances": 1
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 4000,
                "protocol": "HTTP",
                "public": false,
                "security": {
                  "credentials": [],
                  "policies": [],
                  "sso": {}
                }
              }
            ],
            "runtimeEnvironment": {
              "PORT": "4000",
              "NODE_ENV": "production"
            },
            "runtimeFiles": {},
            "buildArguments": {},
            "buildFiles": {},
            "buildConfiguration": {
              "pathIgnoreRules": [],
              "isAllowList": false,
              "ciIgnoreFlagsEnabled": false
            }
          }
        },
        {
          "kind": "CombinedService",
          "ref": "todo-frontend",
          "spec": {
            "projectId": "${refs.todo-fullstack.id}",
            "name": "todo-frontend",
            "description": "Todo React frontend (Nginx)",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "vcsData": {
              "projectType": "github",
              "projectUrl": "${args.GIT_REPO}",
              "projectBranch": "${args.GIT_BRANCH}"
            },
            "buildSettings": {
              "dockerfile": {
                "buildEngine": "kaniko",
                "dockerFilePath": "/frontend/Dockerfile",
                "dockerWorkDir": "/frontend"
              }
            },
            "deployment": {
              "instances": 1
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 80,
                "protocol": "HTTP",
                "public": true,
                "security": {
                  "credentials": [],
                  "policies": [],
                  "sso": {}
                }
              }
            ],
            "runtimeEnvironment": {},
            "runtimeFiles": {},
            "buildArguments": {},
            "buildFiles": {},
            "buildConfiguration": {
              "pathIgnoreRules": [],
              "isAllowList": false,
              "ciIgnoreFlagsEnabled": false
            }
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "gitops": {
    "repoUrl": "https://github.com/dataGriff/northflank.fullstack",
    "vcsService": "github",
    "accountLogin": "dataGriff",
    "branch": "main",
    "filePath": "/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}