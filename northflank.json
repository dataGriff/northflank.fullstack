{
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "spec": {
            "name": "todo-fullstack",
            "description": "Fullstack Todo application - PostgreSQL, Express API, React frontend",
            "region": "europe-west",
            "color": "#6366f1"
          }
        },
        {
          "kind": "Addon",
          "spec": {
            "name": "todo-db",
            "description": "PostgreSQL database for Todo app",
            "type": "postgresql",
            "version": "16",
            "billing": {
              "deploymentPlan": "nf-compute-20",
              "storage": 4096,
              "replicas": 1
            },
            "tlsEnabled": true,
            "externalAccessEnabled": false
          }
        },
        {
          "kind": "DeploymentService",
          "spec": {
            "name": "todo-api",
            "description": "Todo REST API (Node.js / Express)",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "deployment": {
              "instances": 1
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 4000,
                "protocol": "HTTP",
                "public": false,
                "security": {
                  "credentials": [],
                  "policies": [],
                  "sso": {}
                }
              }
            ],
            "runtimeEnvironment": {
              "PORT": "4000",
              "NODE_ENV": "production"
            }
          }
        },
        {
          "kind": "DeploymentService",
          "spec": {
            "name": "todo-frontend",
            "description": "Todo React frontend (Nginx)",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "deployment": {
              "instances": 1
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 80,
                "protocol": "HTTP",
                "public": true,
                "security": {
                  "credentials": [],
                  "policies": [],
                  "sso": {}
                }
              }
            ],
            "runtimeEnvironment": {}
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "gitops": {
    "repoUrl": "https://github.com/dataGriff/northflank.fullstack",
    "vcsService": "github",
    "accountLogin": "dataGriff",
    "branch": "main",
    "filePath": "/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}